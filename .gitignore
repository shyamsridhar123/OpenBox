# DarkForge .gitignore

# OMC orchestration state — local-only, contains internal task state and
# research/evidence artifacts that aren't meant for the public repo.
.omc/
**/.omc/
.remember/
# Track settings and hooks; ignore only session-local Claude data
.claude/transcripts/
.claude/todos/
.claude/cache/

# Sub-agent task output files (JSONL transcripts; can contain large traces)
*.output

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg
build/
dist/
.venv/
**/.venv/
venv/
env/
.python-version

# uv
.uv-cache/

# Node / TypeScript
node_modules/
*.tsbuildinfo
.npm/
dist/
# The portal-frontend ships pure DOM HTML/CSS in dist/ as its source of truth
# (no bundler step). Un-ignore that specific path.
!apps/portal-frontend/dist/
!apps/portal-frontend/dist/**

# Go
*.exe
*.test
*.out

# Bicep build outputs
*.json.bicep
infra/bicep/main.json
infra/bicep/modules/*.json

# Helm
*.tgz
charts/

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Secrets and local config
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12

# OpenSandbox server API key — plaintext local-only secret pulled from cluster.
# Materialized by: kubectl -n opensandbox-system get secret opensandbox-api-key ...
examples/.opensandbox-api-key

# Kata webhook TLS material — regenerate per-cluster via generate-certs.sh
infra/kata-webhook/certs/
azureauth.json
credentials.json
local.settings.json

# Bicep parameters with real subscription/tenant IDs (use .example pattern)
infra/bicep/parameters/*.local.parameters.json
infra/bicep/parameters/prod.parameters.json

# Evidence / run output: not tracked. Logs, screenshots, kubectl captures,
# and demo runs stay local — examples/ holds the runnable scripts.
evidence/
*.tar.gz
*.zip

# Logs
*.log
logs/

# AZ CLI cache leaks
.azure/

# Swarm-specific venv (not matched by **/.venv/)
.venv-swarm/

# Claude Code skill scheduler artifact
.claude/scheduled_tasks.lock

# Portal-api local persistence (cluster-history.json + history.db SQLite).
# Never tracked: regenerated per-environment, may contain user identifiers.
apps/portal-api/data/

# Executor verification leftovers
*.err
