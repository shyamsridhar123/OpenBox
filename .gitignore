# OpenSandbox-on-Azure .gitignore

# OMC orchestration state — local-only, contains internal task state
.omc/state/
.omc/drafts/
.remember/
.claude/

# Sub-agent task output files (JSONL transcripts; can contain large traces)
*.output

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg
build/
dist/
.venv/
venv/
env/
.python-version

# uv
.uv-cache/

# Node / TypeScript
node_modules/
*.tsbuildinfo
.npm/
dist/

# Go
*.exe
*.test
*.out

# Bicep build outputs
*.json.bicep
infra/bicep/main.json
infra/bicep/modules/*.json

# Helm
*.tgz
charts/

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Secrets and local config
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
azureauth.json
credentials.json
local.settings.json

# Bicep parameters with real subscription/tenant IDs (use .example pattern)
infra/bicep/parameters/*.local.parameters.json
infra/bicep/parameters/prod.parameters.json

# Evidence / run output: we DO ship the curated subdirectory at
# evidence/runs/finish/ (runbooks, AC checklist, final report, live-results,
# E2E test scripts and logs). Everything else under evidence/runs/ is local
# scratch and stays ignored. The specific secret files inside
# evidence/runs/finish/ are explicitly listed in the "Secrets that must never
# be committed" block lower in this file.
evidence/runs/*
!evidence/runs/finish/
evidence/screenshots-raw/
*.tar.gz
*.zip

# Logs
*.log
logs/

# AZ CLI cache leaks
.azure/

# Secrets that must never be committed
evidence/runs/finish/.opensandbox-api-key
evidence/runs/finish/aca-kubeconfig/sa.token
evidence/runs/finish/aca-kubeconfig/kubeconfig.yaml
evidence/runs/finish/aca-kubeconfig/ca.crt.b64
evidence/runs/finish/aca-kubeconfig/ca-current.yaml
